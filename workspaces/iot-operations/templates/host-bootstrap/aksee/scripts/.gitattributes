# The minified launcher is delivered inline via template.bicep loadTextContent and
# JSON-encoded onto the Arc runCommand. Pin LF so it stays the smallest on the wire
# (one byte and one JSON escape char less per line than CRLF) regardless of the
# checkout platform or core.autocrlf. It is generated by Build-Launcher.ps1.
Install-AksEeBootstrap.min.ps1 text eol=lf
